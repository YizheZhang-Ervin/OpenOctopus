{
    "agents": {
        "defaults": {
            "workspace": "~/.nanobot/workspace",
            "model": "anthropic/claude-opus-4-5",
            "maxTokens": 8192,
            "temperature": 0.7,
            "maxToolIterations": 20,
            "memoryWindow": 50
        }
    },
    "channels": {
        "email": {
            "enabled": false,
            "consentGranted": false,
            "imapHost": "",
            "imapPort": 993,
            "imapUsername": "",
            "imapPassword": "",
            "imapMailbox": "INBOX",
            "imapUseSsl": true,
            "smtpHost": "",
            "smtpPort": 587,
            "smtpUsername": "",
            "smtpPassword": "",
            "smtpUseTls": true,
            "smtpUseSsl": false,
            "fromAddress": "",
            "autoReplyEnabled": true,
            "pollIntervalSeconds": 30,
            "markSeen": true,
            "maxBodyChars": 12000,
            "subjectPrefix": "Re: ",
            "allowFrom": []
        },
        "httpApi": {
            "enabled": false,
            "host": "0.0.0.0",
            "port": 8000,
            "allowFrom": []
        }
    },
    "providers": {
        "custom": {
            "apiKey": "",
            "apiBase": null,
            "extraHeaders": null
        }
    },
    "gateway": {
        "host": "0.0.0.0",
        "port": 18790
    },
    "tools": {
        "web": {
            "search": {
                "apiKey": "",
                "maxResults": 5
            }
        },
        "filesystem": {
            "allowed_paths": [
                "./workspace",
                "./data"
            ],
            "max_file_size": 10485760
        },
        "exec": {
            "timeout": 60
        },
        "restrictToWorkspace": false,
        "mcpServers": {}
    }
}