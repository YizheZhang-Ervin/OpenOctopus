{
  "name": "octopus",
  "version": "1.0.0",
  "description": "A lightweight AI agent framework built with Node.js",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:run": "node scripts/dev.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "bot",
    "assistant"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "commander": "^11.1.0",
    "inquirer": "^9.2.11",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "marked": "^9.1.6",
    "marked-terminal": "^6.2.0",
    "node-cron": "^3.0.3",
    "ws": "^8.14.2",
    "winston": "^3.11.0",
    "joi": "^17.11.0",
    "fs-extra": "^11.1.1",
    "glob": "^10.3.10",
    "openai": "^4.20.1",
    "mime-types": "^2.1.35",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.8.7",
    "@types/express": "^4.17.20",
    "@types/inquirer": "^9.0.6",
    "@types/ws": "^8.5.8",
    "@types/jest": "^29.5.7",
    "@types/mime-types": "^2.1.3",
    "@types/uuid": "^9.0.6",
    "@types/fs-extra": "^11.0.3",
    "typescript": "^5.2.2",
    "tsx": "^4.1.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.52.0",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "prettier": "^3.0.3"
  }
}