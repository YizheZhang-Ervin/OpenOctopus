{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "node",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "baseUrl": "./src",
        "paths": {
            "@/*": [
                "*"
            ],
            "@/agent/*": [
                "agent/*"
            ],
            "@/bus/*": [
                "bus/*"
            ],
            "@/channels/*": [
                "channels/*"
            ],
            "@/config/*": [
                "config/*"
            ],
            "@/providers/*": [
                "providers/*"
            ],
            "@/tools/*": [
                "tools/*"
            ],
            "@/utils/*": [
                "utils/*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.ts"
    ]
}